# Host port published by Traefik. It binds to 127.0.0.1 only.
HTTP_PORT=8080

# Safe build/runtime metadata; this is not a secret.
APP_VERSION=0.1.0

# Shared low-cardinality resource metadata used by structured logs.
OTEL_SERVICE_NAME=observability-demo-api
OTEL_SERVICE_NAMESPACE=learning
DEPLOYMENT_ENVIRONMENT=local
